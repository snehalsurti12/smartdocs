      "text": "Report Tracking",
      "style": { "size": 9, "weight": 600, "color": "#888" }},
    {"id": "p3_barcode", "type": "barcode", "region": "body", "page": 3,
      "x": 0, "y": 541, "w": 200, "h": 55,
      "value": "{{report.id}}", "format": "code128"},

    {"id": "p4_title", "type": "text", "region": "body", "page": 4,
