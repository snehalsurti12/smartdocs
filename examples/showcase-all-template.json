{
  "id": "tmpl_showcase_all",
  "name": "Quarterly Business Report",
  "version": "1.0.0",
  "unit": "pt",
  "dataSample": "/examples/showcase-all-data.json",
  "pageCount": 4,
  "page": {
    "size": "A4",
    "width": 595,
    "height": 842,
    "margin": { "top": 36, "right": 36, "bottom": 36, "left": 36 },
    "headerHeight": 50,
    "footerHeight": 30
  },
  "fonts": [
    { "name": "Inter", "source": "local" }
  ],
  "styles": {
    "defaultText": { "font": "Inter", "size": 10, "color": "#2d2d2d", "lineHeight": 14 }
  },
  "variables": {
    "currency": "USD"
  },
  "dataContract": {
    "fields": [
      { "path": "company.name", "required": true },
      { "path": "company.tagline" },
      { "path": "report.quarter", "required": true },
      { "path": "report.year", "required": true },
      { "path": "report.date", "transform": "date", "transformDateStyle": "long" },
      { "path": "report.id", "required": true },
      { "path": "kpi.revenue", "transform": "currency" },
      { "path": "kpi.customers", "transform": "number" },
      { "path": "kpi.satisfaction" },
      { "path": "kpi.growth" },
      { "path": "summary", "required": true },
      { "path": "website" }
    ]
  },
  "elements": [

    {"id": "cover_hdr_bg", "type": "box", "region": "header", "page": 1,
      "x": 0, "y": 0, "w": 523, "h": 50,
      "style": { "fill": "#1a2744", "borderWidth": 0, "borderColor": "#1a2744" }},
    {"id": "cover_ftr_bg", "type": "box", "region": "footer", "page": 1,
      "x": 0, "y": 0, "w": 523, "h": 30,
      "style": { "fill": "#1a2744", "borderWidth": 0, "borderColor": "#1a2744" }},
    {"id": "cover_bg", "type": "box", "region": "body", "page": 1,
      "x": 0, "y": 0, "w": 523, "h": 690,
      "style": { "fill": "#1a2744", "borderWidth": 0, "borderColor": "#1a2744" }},
    {"id": "cover_accent_top", "type": "box", "region": "body", "page": 1,
      "x": 0, "y": 0, "w": 523, "h": 6,
      "style": { "fill": "#e8643b", "borderWidth": 0, "borderColor": "#e8643b" }},
    {"id": "cover_image", "type": "image", "region": "body", "page": 1,
      "x": 0, "y": 6, "w": 523, "h": 230,
      "src": "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200&h=600&fit=crop",
      "fit": "cover"},
    {"id": "cover_accent_mid", "type": "box", "region": "body", "page": 1,
      "x": 0, "y": 236, "w": 523, "h": 4,
      "style": { "fill": "#e8643b", "borderWidth": 0, "borderColor": "#e8643b" }},
    {"id": "cover_company", "type": "text", "region": "body", "page": 1,
      "x": 40, "y": 260, "w": 443, "h": 36,
      "text": "{{company.name}}",
      "style": { "size": 30, "weight": 700, "color": "#ffffff" }},
    {"id": "cover_tagline", "type": "text", "region": "body", "page": 1,
      "x": 40, "y": 300, "w": 443, "h": 18,
      "text": "{{company.tagline}}",
      "style": { "size": 12, "color": "#8fa3c4" }},
    {"id": "cover_line", "type": "line", "region": "body", "page": 1,
      "x": 40, "y": 330, "w": 80, "h": 1,
      "style": { "borderColor": "#e8643b", "borderWidth": 2 }},
    {"id": "cover_title", "type": "text", "region": "body", "page": 1,
      "x": 40, "y": 348, "w": 443, "h": 40,
      "text": "Quarterly Business Report",
      "style": { "size": 26, "weight": 700, "color": "#e8643b" }},
    {"id": "cover_quarter", "type": "text", "region": "body", "page": 1,
      "x": 40, "y": 396, "w": 443, "h": 26,
      "text": "{{report.quarter}} {{report.year}}",
      "style": { "size": 17, "weight": 600, "color": "#c0d0e8" }},
    {"id": "cover_date", "type": "text", "region": "body", "page": 1,
      "x": 40, "y": 426, "w": 443, "h": 18,
      "text": "Published: {{report.date}}",
      "style": { "size": 11, "color": "#8fa3c4" }},
    {"id": "cover_barcode", "type": "barcode", "region": "body", "page": 1,
      "x": 40, "y": 470, "w": 180, "h": 55,
      "value": "{{report.id}}", "format": "code128"},

    {"id": "cover_link", "type": "link", "region": "body", "page": 1,
      "x": 40, "y": 530, "w": 260, "h": 14,
      "text": "{{website}}",
      "url": "{{website}}",
      "style": { "size": 10, "color": "#6ba4d9" }},
    {"id": "cover_report_id", "type": "text", "region": "body", "page": 1,
      "x": 40, "y": 560, "w": 200, "h": 16,
      "text": "Report ID: {{report.id}}",
      "style": { "size": 9, "color": "#8fa3c4" }},

    {"id": "hdr_line", "type": "line", "region": "header", "repeat": "afterFirst",
      "x": 0, "y": 40, "w": 523, "h": 1,
      "style": { "borderColor": "#e0ddd4", "borderWidth": 1 }},
    {"id": "hdr_company", "type": "text", "region": "header", "repeat": "afterFirst",
      "x": 0, "y": 18, "w": 300, "h": 16,
      "text": "{{company.name}} — {{report.quarter}} {{report.year}}",
      "style": { "size": 9, "color": "#888", "weight": 600 }},
    {"id": "hdr_page", "type": "text", "region": "header", "repeat": "afterFirst",
      "x": 423, "y": 18, "w": 100, "h": 16,
      "text": "Page {{page.number}} of {{page.count}}",
      "style": { "size": 9, "color": "#888", "align": "right" }},
    {"id": "ftr_line", "type": "line", "region": "footer", "repeat": "afterFirst",
      "x": 0, "y": 0, "w": 523, "h": 1,
      "style": { "borderColor": "#e0ddd4", "borderWidth": 1 }},
    {"id": "ftr_text", "type": "text", "region": "footer", "repeat": "afterFirst",
      "x": 0, "y": 8, "w": 523, "h": 14,
      "text": "Confidential — {{company.name}} — Generated {{report.date}}",
      "style": { "size": 8, "color": "#aaa", "align": "center" }},

    {"id": "p2_title", "type": "text", "region": "body", "page": 2,
      "x": 0, "y": 0, "w": 523, "h": 28,
      "text": "Executive Summary",
      "style": { "size": 22, "weight": 700, "color": "#1a2744" }},
    {"id": "p2_accent", "type": "box", "region": "body", "page": 2,
      "x": 0, "y": 30, "w": 60, "h": 4,
      "style": { "fill": "#e8643b", "borderWidth": 0, "borderColor": "#e8643b" }},
    {"id": "p2_summary", "type": "text", "region": "body", "page": 2,
      "x": 0, "y": 45, "w": 523, "h": 55,
      "text": "{{summary}}",
      "style": { "size": 11, "color": "#444", "lineHeight": 16 }},

    {"id": "kpi_box_1", "type": "box", "region": "body", "page": 2,
      "x": 0, "y": 110, "w": 122, "h": 65,
      "style": { "fill": "#f0f7ff", "borderColor": "#c8ddf5", "borderWidth": 1, "borderRadius": 6 }},
    {"id": "kpi_label_1", "type": "text", "region": "body", "page": 2,
      "x": 10, "y": 117, "w": 102, "h": 14,
      "text": "Revenue",
      "style": { "size": 9, "color": "#6688aa", "weight": 600 }},
    {"id": "kpi_value_1", "type": "text", "region": "body", "page": 2,
      "x": 10, "y": 134, "w": 102, "h": 26,
      "text": "{{kpi.revenue}}",
      "style": { "size": 18, "weight": 700, "color": "#1a2744" }},

    {"id": "kpi_box_2", "type": "box", "region": "body", "page": 2,
      "x": 134, "y": 110, "w": 122, "h": 65,
      "style": { "fill": "#f0fff4", "borderColor": "#b8e6c8", "borderWidth": 1, "borderRadius": 6 }},
    {"id": "kpi_label_2", "type": "text", "region": "body", "page": 2,
      "x": 144, "y": 117, "w": 102, "h": 14,
      "text": "Customers",
      "style": { "size": 9, "color": "#558866", "weight": 600 }},
    {"id": "kpi_value_2", "type": "text", "region": "body", "page": 2,
      "x": 144, "y": 134, "w": 102, "h": 26,
      "text": "{{kpi.customers}}",
      "style": { "size": 18, "weight": 700, "color": "#1a2744" }},

    {"id": "kpi_box_3", "type": "box", "region": "body", "page": 2,
      "x": 268, "y": 110, "w": 122, "h": 65,
      "style": { "fill": "#fff8f0", "borderColor": "#f0d8b8", "borderWidth": 1, "borderRadius": 6 }},
    {"id": "kpi_label_3", "type": "text", "region": "body", "page": 2,
      "x": 278, "y": 117, "w": 102, "h": 14,
      "text": "Satisfaction",
      "style": { "size": 9, "color": "#aa7744", "weight": 600 }},
    {"id": "kpi_value_3", "type": "text", "region": "body", "page": 2,
      "x": 278, "y": 134, "w": 102, "h": 26,
      "text": "{{kpi.satisfaction}}",
      "style": { "size": 18, "weight": 700, "color": "#1a2744" }},

    {"id": "kpi_box_4", "type": "box", "region": "body", "page": 2,
      "x": 401, "y": 110, "w": 122, "h": 65,
      "style": { "fill": "#f5f0ff", "borderColor": "#d0c0f0", "borderWidth": 1, "borderRadius": 6 }},
    {"id": "kpi_label_4", "type": "text", "region": "body", "page": 2,
      "x": 411, "y": 117, "w": 102, "h": 14,
      "text": "Growth",
      "style": { "size": 9, "color": "#7755aa", "weight": 600 }},
    {"id": "kpi_value_4", "type": "text", "region": "body", "page": 2,
      "x": 411, "y": 134, "w": 102, "h": 26,
      "text": "{{kpi.growth}}",
      "style": { "size": 18, "weight": 700, "color": "#1a2744" }},

    {"id": "chart_rev_title", "type": "text", "region": "body", "page": 2,
      "x": 0, "y": 190, "w": 250, "h": 18,
      "text": "Revenue by Region",
      "style": { "size": 13, "weight": 700, "color": "#1a2744" }},
    {"id": "chart_rev", "type": "chart", "region": "body", "page": 2,
      "x": 0, "y": 210, "w": 250, "h": 165,
      "chartType": "bar",
      "dataSource": "{{revenueByRegion}}", "labelField": "region", "valueField": "amount",
      "title": "",
      "colors": ["#1a2744", "#2b6cb3", "#3c8f3a", "#e8643b", "#d4a017"]},

    {"id": "chart_ch_title", "type": "text", "region": "body", "page": 2,
      "x": 273, "y": 190, "w": 250, "h": 18,
      "text": "Sales Channels",
      "style": { "size": 13, "weight": 700, "color": "#1a2744" }},
    {"id": "chart_ch", "type": "chart", "region": "body", "page": 2,
      "x": 273, "y": 210, "w": 250, "h": 165,
      "chartType": "doughnut",
      "dataSource": "{{salesChannels}}", "labelField": "channel", "valueField": "percentage",
      "title": "",
      "colors": ["#e8643b", "#2b6cb3", "#3c8f3a", "#d4a017"]},

    {"id": "team_photo", "type": "image", "region": "body", "page": 2,
      "x": 0, "y": 390, "w": 523, "h": 140,
      "src": "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1200&h=400&fit=crop",
      "fit": "cover"},
    {"id": "team_caption", "type": "text", "region": "body", "page": 2,
      "x": 0, "y": 535, "w": 523, "h": 14,
      "text": "Our team continues to deliver exceptional results across all divisions.",
      "style": { "size": 9, "fontStyle": "italic", "color": "#888" }},

    {"id": "p2_insight_box", "type": "box", "region": "body", "page": 2,
      "x": 0, "y": 560, "w": 523, "h": 60,
      "style": { "fill": "#f8f6f1", "borderColor": "#e6dfd2", "borderWidth": 1, "borderRadius": 6 }},
    {"id": "p2_insight_label", "type": "text", "region": "body", "page": 2,
      "x": 14, "y": 568, "w": 100, "h": 14,
      "text": "Key Insight",
      "style": { "size": 9, "weight": 700, "color": "#e8643b" }},
    {"id": "p2_insight_text", "type": "text", "region": "body", "page": 2,
      "x": 14, "y": 584, "w": 495, "h": 28,
      "text": "North America and Europe account for 65% of total revenue. Direct sales remain the strongest channel at 42%, with partner-driven sales growing fastest quarter-over-quarter.",
      "style": { "size": 10, "color": "#555", "lineHeight": 14 }},

    {"id": "p3_title", "type": "text", "region": "body", "page": 3,
      "x": 0, "y": 0, "w": 523, "h": 28,
      "text": "Top Transactions",
      "style": { "size": 22, "weight": 700, "color": "#1a2744" }},
    {"id": "p3_accent", "type": "box", "region": "body", "page": 3,
      "x": 0, "y": 30, "w": 60, "h": 4,
      "style": { "fill": "#e8643b", "borderWidth": 0, "borderColor": "#e8643b" }},
    {"id": "p3_subtitle", "type": "text", "region": "body", "page": 3,
      "x": 0, "y": 42, "w": 523, "h": 16,
      "text": "Key deals closed in {{report.quarter}} {{report.year}}",
      "style": { "size": 10, "color": "#666" }},

    {"id": "sales_table", "type": "table", "region": "body", "page": 3,
      "x": 0, "y": 68, "w": 523, "h": 220,
      "rows": "{{transactions}}",
      "columns": [
        { "header": "Date", "field": "date", "w": 70, "align": "left" },
        { "header": "Client", "field": "client", "w": 140, "align": "left" },
        { "header": "Product", "field": "product", "w": 110, "align": "left" },
        { "header": "Region", "field": "region", "w": 60, "align": "center" },
        { "header": "Qty", "field": "qty", "w": 40, "align": "right", "format": "number" },
        { "header": "Amount", "field": "amount", "w": 103, "align": "right", "format": "currency" }
      ],
      "headerStyle": { "size": 9, "weight": 700, "color": "#fff", "fill": "#1a2744" },
      "rowStyle": { "size": 9, "color": "#333" }},

    {"id": "p3_chart_title", "type": "text", "region": "body", "page": 3,
      "x": 0, "y": 305, "w": 240, "h": 18,
      "text": "Product Revenue Share",
      "style": { "size": 13, "weight": 700, "color": "#1a2744" }},
    {"id": "p3_chart", "type": "chart", "region": "body", "page": 3,
      "x": 0, "y": 325, "w": 220, "h": 180,
      "chartType": "pie",
      "dataSource": "{{productRevenue}}", "labelField": "product", "valueField": "revenue",
      "title": "",
      "colors": ["#1a2744", "#e8643b", "#2b6cb3"]},

    {"id": "p3_trend_title", "type": "text", "region": "body", "page": 3,
      "x": 250, "y": 305, "w": 273, "h": 18,
      "text": "Monthly Revenue Trend",
      "style": { "size": 13, "weight": 700, "color": "#1a2744" }},
    {"id": "p3_trend", "type": "chart", "region": "body", "page": 3,
      "x": 250, "y": 325, "w": 273, "h": 180,
      "chartType": "line",
      "dataSource": "{{monthlyRevenue}}", "labelField": "month", "valueField": "revenue",
      "title": "",
      "colors": ["#e8643b"]},

    {"id": "p3_barcode_label", "type": "text", "region": "body", "page": 3,
