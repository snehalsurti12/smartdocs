{
  "id": "tmpl_event_pass",
  "name": "Conference Event Pass",
  "version": "1.0.0",
  "unit": "pt",
  "dataSample": "/examples/event-pass-data.json",
  "pageCount": 2,
  "page": {
    "size": "A4",
    "width": 595,
    "height": 842,
    "margin": { "top": 24, "right": 36, "bottom": 24, "left": 36 },
    "headerHeight": 0,
    "footerHeight": 0
  },
  "fonts": [
    { "name": "Inter", "source": "local" }
  ],
  "styles": {
    "defaultText": { "font": "Inter", "size": 10, "color": "#333", "lineHeight": 14 }
  },
  "dataContract": {
    "fields": [
      { "path": "event.name", "required": true },
      { "path": "event.date", "transform": "date", "transformDateStyle": "long" },
      { "path": "event.venue", "required": true },
      { "path": "event.city" },
      { "path": "attendee.name", "required": true },
      { "path": "attendee.title" },
      { "path": "attendee.company" },
      { "path": "attendee.email" },
      { "path": "attendee.id", "required": true },
      { "path": "attendee.type" },
      { "path": "event.website" }
    ]
  },
  "elements": [
    {"id": "badge_bg", "type": "box", "region": "body", "page": 1,
      "x": 60, "y": 40, "w": 403, "h": 560,
      "style": { "fill": "#ffffff", "borderColor": "#e0e0e0", "borderWidth": 1, "borderRadius": 12 }},

    {"id": "badge_top_band", "type": "box", "region": "body", "page": 1,
      "x": 60, "y": 40, "w": 403, "h": 100,
      "style": { "fill": "#0f172a", "borderWidth": 0, "borderColor": "#0f172a", "borderRadius": 12 }},
    {"id": "badge_top_corner_fix", "type": "box", "region": "body", "page": 1,
      "x": 60, "y": 120, "w": 403, "h": 20,
      "style": { "fill": "#0f172a", "borderWidth": 0, "borderColor": "#0f172a" }},

    {"id": "badge_accent", "type": "box", "region": "body", "page": 1,
      "x": 60, "y": 140, "w": 403, "h": 6,
      "style": { "fill": "#6366f1", "borderWidth": 0, "borderColor": "#6366f1" }},

    {"id": "badge_event_name", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 55, "w": 353, "h": 30,
      "text": "{{event.name}}",
      "style": { "size": 20, "weight": 700, "color": "#ffffff", "align": "center" }},
    {"id": "badge_event_details", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 88, "w": 353, "h": 16,
      "text": "{{event.date}} · {{event.venue}}, {{event.city}}",
      "style": { "size": 10, "color": "#94a3b8", "align": "center" }},
    {"id": "badge_event_date_line", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 106, "w": 353, "h": 16,
      "text": "{{event.tagline}}",
      "style": { "size": 9, "color": "#6366f1", "align": "center", "fontStyle": "italic" }},

    {"id": "badge_photo", "type": "image", "region": "body", "page": 1,
      "x": 210, "y": 160, "w": 104, "h": 104,
      "src": "{{attendee.photo}}",
      "fit": "cover"},

    {"id": "badge_name", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 278, "w": 353, "h": 32,
      "text": "{{attendee.name}}",
      "style": { "size": 24, "weight": 700, "color": "#0f172a", "align": "center" }},
    {"id": "badge_title", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 312, "w": 353, "h": 18,
      "text": "{{attendee.title}}",
      "style": { "size": 12, "color": "#64748b", "align": "center" }},
    {"id": "badge_company", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 332, "w": 353, "h": 18,
      "text": "{{attendee.company}}",
      "style": { "size": 13, "weight": 600, "color": "#334155", "align": "center" }},

    {"id": "badge_type_box", "type": "box", "region": "body", "page": 1,
      "x": 195, "y": 362, "w": 133, "h": 28,
      "style": { "fill": "#6366f1", "borderWidth": 0, "borderColor": "#6366f1", "borderRadius": 14 }},
    {"id": "badge_type", "type": "text", "region": "body", "page": 1,
      "x": 195, "y": 367, "w": 133, "h": 18,
      "text": "{{attendee.type}}",
      "style": { "size": 12, "weight": 700, "color": "#ffffff", "align": "center" }},

    {"id": "badge_sep", "type": "line", "region": "body", "page": 1,
      "x": 100, "y": 405, "w": 323, "h": 1,
      "style": { "borderColor": "#e2e8f0", "borderWidth": 1 }},

    {"id": "badge_qr", "type": "qr", "region": "body", "page": 1,
      "x": 196, "y": 420, "w": 130, "h": 130,
      "value": "{{attendee.checkinUrl}}",
      "ecc": "M"},
    {"id": "badge_qr_label", "type": "text", "region": "body", "page": 1,
      "x": 85, "y": 555, "w": 353, "h": 14,
      "text": "Scan to check in · ID: {{attendee.id}}",
      "style": { "size": 9, "color": "#94a3b8", "align": "center" }},

    {"id": "badge_barcode", "type": "barcode", "region": "body", "page": 1,
      "x": 160, "y": 575, "w": 203, "h": 40,
      "value": "{{attendee.id}}", "format": "code128"},

    {"id": "p2_title", "type": "text", "region": "body", "page": 2,
      "x": 0, "y": 20, "w": 523, "h": 28,
      "text": "Event Schedule",
      "style": { "size": 22, "weight": 700, "color": "#0f172a" }},
    {"id": "p2_accent", "type": "box", "region": "body", "page": 2,
      "x": 0, "y": 50, "w": 60, "h": 4,
      "style": { "fill": "#6366f1", "borderWidth": 0, "borderColor": "#6366f1" }},

    {"id": "schedule_table", "type": "table", "region": "body", "page": 2,
      "x": 0, "y": 70, "w": 523, "h": 250,
      "rows": "{{schedule}}",
      "columns": [
        { "header": "Time", "field": "time", "w": 80, "align": "left" },
        { "header": "Session", "field": "session", "w": 230, "align": "left" },
        { "header": "Speaker", "field": "speaker", "w": 120, "align": "left" },
        { "header": "Room", "field": "room", "w": 93, "align": "center" }
      ],
      "headerStyle": { "size": 9, "weight": 700, "color": "#fff", "fill": "#0f172a" },
      "rowStyle": { "size": 9, "color": "#333" }},

    {"id": "p2_stats_title", "type": "text", "region": "body", "page": 2,
      "x": 0, "y": 340, "w": 523, "h": 18,
      "text": "Session Topics",
      "style": { "size": 13, "weight": 700, "color": "#0f172a" }},
    {"id": "p2_chart", "type": "chart", "region": "body", "page": 2,
      "x": 0, "y": 360, "w": 250, "h": 180,
      "chartType": "doughnut",
      "dataSource": "{{topicBreakdown}}",
      "labelField": "topic", "valueField": "count",
      "title": "",
      "colors": ["#6366f1", "#ec4899", "#f59e0b", "#10b981", "#3b82f6"]},

    {"id": "p2_venue_title", "type": "text", "region": "body", "page": 2,
      "x": 270, "y": 340, "w": 253, "h": 18,
      "text": "Venue Information",
      "style": { "size": 13, "weight": 700, "color": "#0f172a" }},
    {"id": "p2_venue_img", "type": "image", "region": "body", "page": 2,
      "x": 270, "y": 360, "w": 253, "h": 120,
      "src": "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&h=300&fit=crop",
      "fit": "cover"},
    {"id": "p2_venue_name", "type": "text", "region": "body", "page": 2,
      "x": 270, "y": 485, "w": 253, "h": 16,
      "text": "{{event.venue}}, {{event.city}}",
      "style": { "size": 10, "weight": 600, "color": "#334155" }},
    {"id": "p2_venue_link", "type": "link", "region": "body", "page": 2,
      "x": 270, "y": 504, "w": 253, "h": 14,
      "text": "View venue map & directions →",
      "url": "{{event.venueMapUrl}}",
      "style": { "size": 10, "color": "#6366f1" }},

    {"id": "p2_wifi_box", "type": "box", "region": "body", "page": 2,
      "x": 0, "y": 560, "w": 250, "h": 80,
      "style": { "fill": "#f8fafc", "borderColor": "#e2e8f0", "borderWidth": 1, "borderRadius": 8 }},
    {"id": "p2_wifi_title", "type": "text", "region": "body", "page": 2,
      "x": 14, "y": 568, "w": 120, "h": 14,
      "text": "Wi-Fi Access",
      "style": { "size": 10, "weight": 700, "color": "#0f172a" }},
    {"id": "p2_wifi_net", "type": "text", "region": "body", "page": 2,
      "x": 14, "y": 586, "w": 120, "h": 14,
      "text": "Network: {{wifi.network}}",
      "style": { "size": 9, "color": "#64748b" }},
    {"id": "p2_wifi_pass", "type": "text", "region": "body", "page": 2,
      "x": 14, "y": 600, "w": 120, "h": 14,
      "text": "Password: {{wifi.password}}",
      "style": { "size": 9, "color": "#64748b" }},
    {"id": "p2_wifi_qr", "type": "qr", "region": "body", "page": 2,
      "x": 160, "y": 565, "w": 70, "h": 70,
      "value": "WIFI:T:WPA;S:{{wifi.network}};P:{{wifi.password}};;",
      "ecc": "M"},

    {"id": "p2_emergency_box", "type": "box", "region": "body", "page": 2,
      "x": 270, "y": 560, "w": 253, "h": 80,
      "style": { "fill": "#f8fafc", "borderColor": "#e2e8f0", "borderWidth": 1, "borderRadius": 8 }},
    {"id": "p2_emergency_title", "type": "text", "region": "body", "page": 2,
      "x": 284, "y": 568, "w": 225, "h": 14,
      "text": "Need Help?",
      "style": { "size": 10, "weight": 700, "color": "#0f172a" }},
    {"id": "p2_emergency_text", "type": "text", "region": "body", "page": 2,
      "x": 284, "y": 586, "w": 225, "h": 44,
      "text": "Visit the Info Desk in the Main Lobby or contact event support at {{event.supportEmail}}",
      "style": { "size": 9, "color": "#64748b", "lineHeight": 13 }},

    {"id": "p2_footer_line", "type": "line", "region": "body", "page": 2,
      "x": 0, "y": 660, "w": 523, "h": 1,
      "style": { "borderColor": "#e2e8f0", "borderWidth": 1 }},
    {"id": "p2_footer_qr", "type": "qr", "region": "body", "page": 2,
      "x": 0, "y": 670, "w": 60, "h": 60,
      "value": "{{event.website}}",
      "ecc": "M"},
    {"id": "p2_footer_event", "type": "text", "region": "body", "page": 2,
      "x": 70, "y": 680, "w": 300, "h": 16,
      "text": "{{event.name}} · {{event.date}}",
      "style": { "size": 10, "weight": 600, "color": "#0f172a" }},
    {"id": "p2_footer_link", "type": "link", "region": "body", "page": 2,
      "x": 70, "y": 698, "w": 300, "h": 14,
      "text": "{{event.website}}",
      "url": "{{event.website}}",
      "style": { "size": 9, "color": "#6366f1" }},
    {"id": "p2_footer_barcode", "type": "barcode", "region": "body", "page": 2,
      "x": 380, "y": 670, "w": 143, "h": 45,
      "value": "{{attendee.id}}", "format": "code128"}
  ]
}
